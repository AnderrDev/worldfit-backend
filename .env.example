# Copien este archivo como .env (cp .env.example .env) y completen los valores locales.
# El archivo .env NUNCA se sube a git (cada integrante lo configura en su maquina).

PORT=4000

# PostgreSQL
DB_HOST=localhost
# Con Docker se usa 5433 (ver docker-compose.yml). Si usas un PostgreSQL
# instalado localmente, cambia a 5432.
DB_PORT=5433
DB_USER=postgres
# Si usas Docker (docker compose up -d), la contrasena es: postgres
DB_PASSWORD=tu_password
DB_NAME=worldfit
DB_SCHEMA=worldfit

# Clave para firmar los JWT. Minimo 32 caracteres, aleatoria y secreta.
JWT_SECRET=cambia_esto_por_una_clave_de_32_o_mas_caracteres

# Versionado de la API (URI versioning). Resultado: {API_PREFIX}/{API_VERSION}
# Por defecto los endpoints quedan bajo /api/v1
API_PREFIX=/api
API_VERSION=v1
