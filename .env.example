# Copia este archivo a `.env` (cp .env.example .env) y completa los valores.
# El archivo .env NUNCA se sube a git.

PORT=3000
NODE_ENV=development

# Conexion a MongoDB.
# Pega aqui la "connection string" que te da MongoDB Atlas. Formato:
#   mongodb+srv://USUARIO:CONTRASENA@cluster0.xxxxx.mongodb.net/worldfit?retryWrites=true&w=majority
# - Reemplaza USUARIO y CONTRASENA por los del Database User que creaste en Atlas.
# - El "/worldfit" antes del "?" es el nombre de la base de datos (puede ser el que quieras).
# Si en vez de Atlas usas Mongo local, deja: mongodb://localhost:27017/worldfit
MONGO_URI=mongodb://localhost:27017/worldfit

# Secreto para firmar los JWT. Pon cualquier texto largo y aleatorio.
JWT_SECRET=cambia-este-secreto
JWT_EXPIRES_IN=1d

# Rutas de la API (parametrizables). Valores por defecto si se omiten:
# - API_PREFIX  : prefijo base para endpoints de infraestructura (health, docs). Default: /api
# - API_VERSION : version de los endpoints de negocio. Default: v1
# Resultado: negocio en {API_PREFIX}/{API_VERSION} (ej. /api/v1/exercises),
#            health/docs en {API_PREFIX} (ej. /api/health, /api/docs).
API_PREFIX=/api
API_VERSION=v1
