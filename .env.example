# Copien este archivo como .env (cp .env.example .env) y completen los valores locales.
# El archivo .env NUNCA se sube a git (cada integrante lo configura en su maquina).

PORT=4000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password
DB_NAME=worldfit
DB_SCHEMA=worldfit

# Clave para firmar los JWT. Minimo 32 caracteres, aleatoria y secreta.
JWT_SECRET=cambia_esto_por_una_clave_de_32_o_mas_caracteres
